PORT=3001
STORAGE_DIR=./storage
MAX_UPLOAD_MB=10
CORS_ORIGIN=http://localhost:5173
UPLOAD_RATE_LIMIT_PER_MINUTE=4
PREPROCESS_MAX_DIMENSION=2048
TRACE_THRESHOLD=180
TRACE_TURD_SIZE=4
TRACE_OPT_TOLERANCE=0.18

GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_SIZE=2K
AI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Optional. Isi hanya jika backend Cloud Run dipanggil dari Worker/proxy tepercaya.
PROCESSOR_API_KEY=
